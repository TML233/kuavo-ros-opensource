; 手臂轨迹插补限制（仅用于上层 armTrajInterpFilter），与 optimizedTrajKinematicLimit 解耦
armTrajInterpKinematicLimit
{
  enable                         false  ; false: 保持旧版逻辑, true: 启用手臂轨迹插补增强路径
  reference_update_period        0.010  ; [s], should match arm trajectory source period
  kalman_r_q                     3e-7    ; PV模型: 全14DoF共享 position measurement noise
  kalman_r_dq                    5e-4    ; PV模型: 全14DoF共享 velocity measurement noise
  kalman_p0_pos                  1e-2    ; PV模型: 全14DoF共享 initial covariance (position)
  kalman_p0_vel                  5e-1    ; PV模型: 全14DoF共享 initial covariance (velocity)
  kalman_v_limit                 30.0    ; PV模型: 全14DoF共享 velocity limit [rad/s]
  fast_update_r_scale            1.0     ; 量测噪声缩放（1.0=常规更新）
  immediate_update_on_new_target true    ; 新目标到达后立即更新，不受周期门控阻塞
  target_v_alpha                 0.80    ; targetV去毛刺系数，1.0表示关闭；无新rawV时预测保持v常值

  ; fhan 跟踪微分器参数（动力学约束 q/dq 平滑层）
  ; fhan_r: 等效加速度阈值 [rad/s^2]，越大跟踪越快但响应越硬
  ; fhan_h0_ratio: h0 = ratio * controlCycleSec，建议 2~5
  fhan_r                         5000.0
  fhan_h0_ratio                  3.0
}


