; Dance Controller Configuration File
; 舞蹈控制器配置文件

withArm                 true    ; 是否使用手臂 0:不使用 1:使用
inferenceFrequency      50      ; 推理频率（Hz），建议保持50Hz

actionScale             1.0     ; 全局动作缩放系数
frameStack              1       ; 帧堆叠数量（历史帧数）
numSingleObs            118     ; 单帧观测维度（根据singleInputData计算）
clipObservations        5000.0  ; 观测裁剪限制
clipActions             5000.0  ; 动作裁剪限制

; Dance控制器特定参数
 
trajectoryCSVFile       hsy_aiqingniao_0420_55000.csv   ; 
trajectoryTimeStep      0.02    ; 轨迹时间步长（秒），默认50Hz
holdFrameIndex          -1      ; 轨迹完成后保持的帧索引（-1表示最后一帧，>=0表示指定帧, -2表示结束后自动切换到amp）


networkModelFile        /wh_aiqingniao_0423_7000.onnx 

residualAction          true


defaultBaseHeightControl    0.76 ; 站立时的基座高度
is_fall_down_controller     false ; 是否为倒地起身控制器
use_interploate_from_mpc    true  ; 从MPC切换到dance时使用插值过渡到默认姿态
use_dance_ruiwo_kpkd        true  ; 是否使用 Dance 专用 Ruiwo 手臂增益

