<?xml version="1.0" ?>

<launch>
  <!--
    Wheel playback (no sim):
    - No Mujoco
    - No MPC node
    - No hardware node
    - Data source is rosbag play
  -->
  <arg name="robot_version"      default="$(optenv ROBOT_VERSION 62)"/>
  <arg name="rviz"               default="true"/>
  <arg name="multiplot"          default="false"/>
  <arg name="wbc_frequency"      default="500"/>
  <arg name="sensor_frequency"   default="500"/>
  <arg name="use_external_mpc"   default="true"/>
  <arg name="with_estimation"    default="true"/>
  <arg name="use_joint_filter"   default="false"/>
  <arg name="estimator_type"     default="1"/>
  <arg name="wbc_only"           default="false"/>
  <arg name="play_back"          default="true"/>

  <!-- 轮臂链路参数 -->
  <arg name="robot_type"         default="1"/>
  <arg name="nodelet_robot_type" default="1"/>
  <arg name="wheel_control_type" default="1"/>
  <arg name="joystick_type"      default="sim"/>
  <arg name="arm_move_spd"       default="1.2"/>
  <arg name="start_way"          default="manual"/>
  <arg name="use_estimator_contact" default="false"/>

  <!-- 文件参数 -->
  <arg name="urdfFile"       default="$(find kuavo_assets)/models/biped_s$(arg robot_version)/urdf/biped_s$(arg robot_version).urdf"/>
  <arg name="taskFile"       default="$(find humanoid_wheel_interface)/config/kuavo_s$(arg robot_version)/task.info"/>
  <arg name="libFolder"      default="/var/ocs2/kuavo_s$(arg robot_version)"/>
  <arg name="referenceFile"  default="$(find humanoid_controllers)/config/kuavo_v$(arg robot_version)/command/reference.info"/>
  <arg name="gaitCommandFile" default="$(find humanoid_controllers)/config/kuavo_v$(arg robot_version)/command/gait.info"/>

  <group if="$(arg rviz)">
    <param name="robot_description" textfile="$(arg urdfFile)"/>
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find humanoid_wheel_interface_ros)/rviz/mobile_manipulator.rviz"
          output="screen" />
  </group>

  <group if="$(arg multiplot)">
    <include file="$(find humanoid_interface_ros)/launch/multiplot.launch"/>
  </group>

  <!-- 全局参数 -->
  <param name="robot_version" value="$(arg robot_version)"/>
  <param name="multiplot" value="$(arg multiplot)"/>
  <param name="wbc_only" value="$(arg wbc_only)"/>
  <param name="use_external_mpc" value="$(arg use_external_mpc)"/>
  <param name="wbc_frequency" value="$(arg wbc_frequency)"/>
  <param name="sensor_frequency" value="$(arg sensor_frequency)"/>
  <param name="with_estimation" value="$(arg with_estimation)"/>
  <param name="use_joint_filter" value="$(arg use_joint_filter)"/>
  <param name="estimator_type" value="$(arg estimator_type)"/>
  <param name="play_back" value="$(arg play_back)"/>
  <!-- 回放模式下不发布 odom->base_link tf，使用 bag 中的 tf -->
  <param name="use_external_odom_tf" type="bool" value="$(arg play_back)"/>
  <param name="joystick_type" value="$(arg joystick_type)"/>
  <param name="arm_move_spd" value="$(arg arm_move_spd)"/>
  <param name="start_way" value="$(arg start_way)"/>
  <param name="use_estimator_contact" value="$(arg use_estimator_contact)"/>
  <param name="build_cppad_state" value="0"/>
  <param name="robot_type" value="$(arg robot_type)"/>
  <param name="nodelet_robot_type" value="$(arg nodelet_robot_type)"/>
  <param name="wheel_control_type" value="$(arg wheel_control_type)"/>
  <param name="taskFile" value="$(arg taskFile)"/>
  <param name="urdfFile" value="$(arg urdfFile)"/>
  <param name="libFolder" value="$(arg libFolder)"/>
  <param name="referenceFile" value="$(arg referenceFile)"/>
  <param name="gaitCommandFile" value="$(arg gaitCommandFile)"/>

  <!-- 仅启动控制 nodelet，不启动仿真/硬件 -->
  <node pkg="nodelet" type="nodelet" name="nodelet_manager"
        args="manager" respawn="false" output="screen" required="true" clear_params="true">
    <param name="num_worker_threads" type="int" value="10" />
  </node>
  <node pkg="nodelet" type="nodelet" name="nodelet_controller"
        args="load HumanoidControllerNodelet nodelet_manager"
        respawn="false" output="screen" required="true"/>
</launch>
