<?xml version="1.0" ?>
<launch>
    <arg name="joystick_type" default="sim"/>
    <arg name="sim_input_mode" default="keyboard"/>
    <node if="$(eval arg('sim_input_mode') == 'keyboard')" pkg="humanoid_interface_ros" type="joystickSimulator.py" name="joystickSimulator" output="screen" launch-prefix="gnome-terminal --disable-factory --"/>
    <node if="$(eval arg('sim_input_mode') == 'gui')" pkg="humanoid_interface_ros" type="joystickSimulator_gui.py" name="joystickSimulator" output="screen" launch-prefix="gnome-terminal --disable-factory --"/>
    
    <param name="channel_map_path" value="$(find humanoid_controllers)/launch/joy/$(arg joystick_type).json"/>
    <param name="joystick_sensitivity" value="40"/>
    <node pkg="humanoid_interface_ros" type="humanoid_joy_control_auto_gait_with_vel" name="humanoid_joy_control_auto_gait_with_vel" output="screen">
    </node>
</launch>
